# Required
BOT_TOKEN=123456789:your_bot_token_here
OWNER_ID=123456789
API_ID=your_api_id
API_HASH=your_api_hash

# Local Bot API server (enables 2GB uploads)
TELEGRAM_BASE_URL=http://localhost:8081/bot

# Log channels (optional, negative IDs for channels/supergroups)
# LOG_CHANNEL=-100123456789
# LOG_EXCEPTION_CHANNEL=-100123456789

# Require users to join a channel before using the bot (optional)
# REQUIRED_CHANNEL=@yourchannel

# Proxy (optional)
# PROXY_1_URL=http://user:pass@1.2.3.4:3128
# PROXY_2_URL=socks5://user:pass@1.2.3.4:1080
# PROXY_STRATEGY=round_robin
# PROXY_DOMAINS=["instagram.com","twitter.com"]

# YouTube PO Token provider (runs alongside the bot)
YOUTUBE_POT_ENABLED=true
YOUTUBE_POT_URL=http://localhost:4416

# YouTube cookie rotation (comma-separated URLs)
# YOUTUBE_COOKIE_URLS=["http://my-config-server/cookies/yt1.txt"]
# YOUTUBE_COOKIE_STRATEGY=round_robin

# Per-service cookies
# INSTAGRAM_COOKIE_URL=http://my-config-server/cookies/instagram.txt
# TIKTOK_COOKIE_URL=http://my-config-server/cookies/tiktok.txt

# Limits
MAX_FILE_SIZE_GB=2.0
DOWNLOAD_TIMEOUT=1200
MAX_PLAYLIST_COUNT=50
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=30
RATE_LIMIT_PER_DAY=100

# Database
DATABASE_URL=postgresql+asyncpg://yoink:yoink@localhost:5432/yoink
DATABASE_ECHO=false
POSTGRES_USER=yoink
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yoink

# Default UI language
DEFAULT_LANGUAGE=en

# Kasm browser (for cookie export via cookies profile)
KASM_VNC_PW=changeme

# Python
PYTHONDONTWRITEBYTECODE=1

# API
API_SECRET_KEY=change-me-in-production
DEBUG=false

# Browser profile for automatic cookie extraction (no manual export needed)
# Mount the Chromium profile directory read-only into the bot container.
# yt-dlp reads cookies directly from the SQLite Cookies file.
# BROWSER_PROFILE_PATH=/app/data/browser-profile
# BROWSER_COOKIE_DOMAINS=["youtube.com","googlevideo.com","google.com"]
# Access control is managed via Admin UI -> Bot Settings (RBAC min role).

# Traefik domains (used in docker-compose.yml labels)
YOINK_DOMAIN=yoink.example.com
KASM_DOMAIN=kasm.example.com
AUTHENTIK_URL=https://auth.example.com
